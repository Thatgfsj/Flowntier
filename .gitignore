*.swp
*.swo
*~

# ─── Secrets & Env ───────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.cer
*.pfx
# Only ignore top-level /secrets/ (project-level credential
# vault convention). Nested src/secrets/ modules must be tracked.
/secrets/

# ─── Rust ────────────────────────────────────────────
/target/
**/target/
**/*.rs.bk
Cargo.lock.bak
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/

# ─── Node / TypeScript ───────────────────────────────
node_modules/
.pnpm-store/
.turbo/
.parcel-cache/
.vite/
apps/desktop/dist/

# ─── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/
*.egg

# ─── Coverage / Cache ────────────────────────────────
coverage/
.coverage
htmlcov/
.nyc_output/

# ─── Logs & Runtime Data ────────────────────────────
*.log
logs/
*.pid
*.seed
*.pid.lock

# ─── Local Storage (Flowntier specific) ────────────────
.storage/
storage/local/
storage/cache/
storage/sessions/
.agent-memory/
.aco/
.acod/

# ─── Dev / Test Scripts (one-off, not for repo) ──────
test_install.bat
test_*.bat
scripts/local/

# ─── Build Outputs ───────────────────────────────────
dist/
build/
out/
*.zip
*.tar.gz
*.tgz

# ─── Tauri bundles ───────────────────────────────────
*.app
*.dmg
*.msi
*.exe
*.deb
*.rpm
*.AppImage

# ─── SQLite runtime databases (regenerated per acceptance run) ───
*.db
*.db-shm
*.db-wal

# ─── Rust ────────────────────────────────────────────────
# Cargo.lock IS committed (the apps are binaries, not a library
# crate — see docs/TECH_STACK.md §2). Do NOT add `Cargo.lock`
# to this file; if you need to ignore it temporarily for a
# test, use `git update-index --skip-worktree`.
apps/desktop/src-tauri/binaries/

# ─── Signing keys (NEVER commit; the private key goes in
#     GitHub repo secrets as TAURI_SIGNING_PRIVATE_KEY) ─────
/.keys/
apps/desktop/.keys/
