{
  "name": "@flowntier/desktop",
  "version": "0.4.11",
  "private": true,
  "type": "module",
  "description": "Tauri 2 + React 19 desktop shell for Flowntier",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles nsis",
    "tauri:patch": "node ../../scripts/patch-nsis.cjs",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@flowntier/prompts": "workspace:*",
    "@flowntier/providers": "workspace:*",
    "@flowntier/shared": "workspace:*",
    "@flowntier/ui": "workspace:*",
    "@flowntier/workflow": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "@tauri-apps/api": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.11.0",
    "framer-motion": "^11.11.0",
    "i18next": "^24.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^6.27.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "happy-dom": "^15.11.0",
    "playwright": "^1.61.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  }
}
