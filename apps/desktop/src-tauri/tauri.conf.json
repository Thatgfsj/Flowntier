{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Agent Company OS",
  "version": "0.2.3",
  "identifier": "dev.aco.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Company OS",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:1421 http://127.0.0.1:7317 ws://127.0.0.1:7317"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI Software Company OS",
    "longDescription": "Agent Company OS — a visual AI software company powered by multi-agent workflow.",
    "externalBin": [
      "binaries/aco_runtime"
    ],
    "resources": [
      "WebView2Loader.dll"
    ],
    "publisher": "Thatgfsj"
  }
}
